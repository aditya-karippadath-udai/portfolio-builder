<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #0f0f0f;
      color: #f0f0f0;
      line-height: 1.7;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      padding: 1.25rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(15,15,15,0.85);
      backdrop-filter: blur(10px);
      z-index: 100;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    nav .logo {
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    nav a {
      color: #aaa;
      text-decoration: none;
      font-size: 0.9rem;
      margin-left: 2rem;
      transition: color 0.2s;
    }

    nav a:hover { color: #fff; }

    section {
      padding: 6rem 2.5rem;
      max-width: 960px;
      margin: 0 auto;
    }

    /* Hero */
    #hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 8rem;
    }

    #hero .tag {
      font-size: 0.85rem;
      color: #888;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
    }

    #hero h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 1.5rem;
    }

    #hero h1 span { color: #888; }

    #hero p {
      font-size: 1.15rem;
      color: #aaa;
      max-width: 540px;
      margin-bottom: 2.5rem;
    }

    #hero .cta {
      display: inline-block;
      padding: 0.8rem 2rem;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 4px;
      color: #fff;
      text-decoration: none;
      font-size: 0.95rem;
      transition: background 0.2s, border-color 0.2s;
    }

    #hero .cta:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.4);
    }

    /* About */
    #about .section-label {
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 1rem;
    }

    #about h2 {
      font-size: 2rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    #about p {
      color: #aaa;
      font-size: 1.05rem;
      max-width: 640px;
    }

    /* Projects */
    #projects .section-label {
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 1rem;
    }

    #projects h2 {
      font-size: 2rem;
      font-weight: 600;
      margin-bottom: 2.5rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .project-card {
      background: #1a1a1a;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 8px;
      padding: 1.75rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .project-card:hover {
      border-color: rgba(255,255,255,0.2);
      transform: translateY(-3px);
    }

    .project-card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    .project-card p {
      font-size: 0.95rem;
      color: #888;
      line-height: 1.6;
    }

    /* Dynamic sections */
    .dynamic-section .section-label {
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 1rem;
    }

    .dynamic-section h2 {
      font-size: 2rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .dynamic-section p {
      color: #aaa;
      font-size: 1.05rem;
      max-width: 640px;
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 3rem 2.5rem;
      border-top: 1px solid rgba(255,255,255,0.06);
      color: #555;
      font-size: 0.9rem;
    }